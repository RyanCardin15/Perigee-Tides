{
  "name": "@ryancardin/noaa-tides-currents-mcp-server",
  "version": "2.0.0",
  "description": "MCP server for NOAA CO-OPS Tides and Currents: water levels, tide predictions, currents, meteorology, station metadata, datums, high tide flooding, sea level trends, plus sun and moon calculations",
  "main": "dist/index.js",
  "bin": {
    "noaa-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http --port 3000",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --http --port 3000",
    "test": "vitest run",
    "test:live": "node scripts/smoke-live.mjs",
    "format": "prettier --write .",
    "inspector": "npx @modelcontextprotocol/inspector ./dist/index.js"
  },
  "keywords": [
    "noaa",
    "tides",
    "currents",
    "co-ops",
    "water-levels",
    "tide-predictions",
    "mcp",
    "model-context-protocol",
    "api"
  ],
  "author": "Ryan Cardin",
  "repository": {
    "type": "git",
    "url": "https://github.com/RyanCardin15/NOAA-Tides-And-Currents-MCP.git"
  },
  "bugs": {
    "url": "https://github.com/RyanCardin15/NOAA-Tides-And-Currents-MCP/issues"
  },
  "homepage": "https://github.com/RyanCardin15/NOAA-Tides-And-Currents-MCP#readme",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.7.9",
    "express": "^5.0.0",
    "suncalc": "^1.9.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "prettier": "^3.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
